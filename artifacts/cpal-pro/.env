# Lead-generation chatbot widget — per-environment config.
#
# These values are injected into index.html (%VITE_WIDGET_TENANT% /
# %VITE_WIDGET_API%) and read by the widget at runtime as data-tenant / data-api.
#
# This file is the BASE/default and is loaded in every mode. It targets the
# staging backend with the `nurturenext` tenant — i.e. exactly the working
# local + staging setup. Production overrides these in .env.production.
VITE_WIDGET_TENANT=nurturenext
VITE_WIDGET_API=https://api-multi-tenant.azurewebsites.net/api/v1
